// AdsHub backend data model — see .ai/schema.md.
// Verdict/status/on-off are NOT stored; lib/kpi.ts derives them from InsightSnapshot
// metrics + Product thresholds at read time.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------- Auth & secrets ----------------
model User {
  id               String        @id @default(cuid())
  username         String?       @unique // login identifier (admin-managed)
  email            String        @unique
  name             String
  initials         String
  role             String        @default("member")
  passwordHash     String? // null = no password set yet (pre-seed); set by seed/admin
  failedLoginCount Int           @default(0) // brute-force counter; reset on success
  lockedUntil      DateTime? // temporary lockout after too many failures
  createdAt        DateTime      @default(now())
  logs             ActivityLog[]
  tokens           MetaToken[]
  uploads          Attachment[]
  sessions         Session[]
}

// Opaque database-backed sessions. The raw token lives only in the client's
// httpOnly cookie; we store just its SHA-256 hash so a DB leak yields no usable
// token, and a single session is revoked by deleting one row.
model Session {
  id         String   @id @default(cuid())
  tokenHash  String   @unique // SHA-256 hex of the opaque cookie token
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) // anchor for the absolute expiry cap
  expiresAt  DateTime // sliding expiry; bumped on each verified use
  lastUsedAt DateTime @default(now())
  userAgent  String?
  ip         String?

  @@index([userId])
  @@index([expiresAt])
}

// ---------------- Object storage (Supabase Storage) ----------------
// Bytes live in a Supabase Storage bucket; this table holds only metadata +
// the object key (`path`) and a resolvable `url`. Never store file bytes here.
enum AttachmentKind {
  PRODUCT_IMAGE
  CREATIVE
  OTHER
}

model Attachment {
  id           String         @id @default(cuid())
  kind         AttachmentKind @default(OTHER)
  bucket       String
  path         String // object key within the bucket
  url          String // public (or signed-base) URL used by <img src>
  mimeType     String
  sizeBytes    Int
  width        Int?
  height       Int?
  originalName String?
  uploadedById String?
  uploadedBy   User?          @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime       @default(now())
  products     Product[] // products using this as their image

  @@unique([bucket, path])
}

enum TokenKind {
  USER
  SYSTEM
}

model MetaToken {
  id             String    @id @default(cuid())
  kind           TokenKind
  accessTokenEnc Bytes // encrypted at rest — never sent to client
  scopes         String[]
  businessId     String?
  expiresAt      DateTime?
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  createdAt      DateTime  @default(now())
}

// ---------------- Domain ----------------
enum ConnStatus {
  ACTIVE
  SYNCING
  WARNING
}

model AdAccount {
  id            String           @id @default(cuid())
  metaAccountId String           @unique
  name          String
  platform      String
  initials      String
  color         String
  currency      String           @default("THB")
  connected     Boolean          @default(true)
  status        ConnStatus       @default(ACTIVE)
  lastSyncAt    DateTime?
  products      ProductAccount[]
  campaigns     Campaign[]
  breakdowns    BreakdownSnapshot[]
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  isBuiltIn Boolean   @default(false)
  products  Product[]
}

// Per-product close policy when a campaign breaches its KPIs:
// OFF = ignore · SUGGEST = flag in the "should close" group · AUTO = auto-pause (env-gated).
enum CloseMode {
  OFF
  SUGGEST
  AUTO
}

model Product {
  id         String           @id @default(cuid())
  sku        String           @unique
  thName     String
  unitCost   Int
  imgUrl     String? // legacy/external (e.g. Meta) URL; prefer `image` relation
  imageId    String?
  image      Attachment?      @relation(fields: [imageId], references: [id])
  custom     Boolean          @default(false)
  sortOrder  Int              @default(0) // manual display order (drag-to-reorder in Product KPI)
  closeMode  CloseMode        @default(SUGGEST) // OFF | SUGGEST (advisory) | AUTO (auto-pause)
  skipMetrics String[]        @default([]) // MetricKeys excluded from judging (exceptions)
  categoryId String
  category   Category         @relation(fields: [categoryId], references: [id])
  thrRoas    Float
  thrCtr     Float
  thrCpa     Int
  thrCpm     Int
  thrCpp     Int
  thrCpr     Int
  thrCost    Int
  // Tougher "scale" targets for the judged KPI set (roas/ctr/cpm/cpp). Nullable:
  // existing rows fall back to a value derived from the limit at read time.
  scaleRoas  Float?
  scaleCtr   Float?
  scaleCpm   Int?
  scaleCpp   Int?
  accounts   ProductAccount[]
  campaigns  Campaign[]
  creatives  Creative[]
}

model ProductAccount {
  productId   String
  adAccountId String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  adAccount   AdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)

  @@id([productId, adAccountId])
}

// ---------------- Meta cache ----------------
enum AdStatus {
  ACTIVE
  PAUSED
}

enum ChangeActor {
  MANUAL
  AUTO
  META
}

model Campaign {
  id               String             @id @default(cuid())
  metaCampaignId   String             @unique
  name             String
  status           AdStatus
  effectiveStatus  String?
  objective        String?
  dailyBudgetMinor Int
  statusSource     ChangeActor        @default(META)
  adAccountId      String
  adAccount        AdAccount          @relation(fields: [adAccountId], references: [id])
  productId        String?
  product          Product?           @relation(fields: [productId], references: [id])
  syncedAt         DateTime
  adsets           AdSet[]
  creatives        CampaignCreative[]
  insights         InsightSnapshot[]
}

model AdSet {
  id               String   @id @default(cuid())
  metaAdSetId      String   @unique
  campaignId       String
  campaign         Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name             String
  status           AdStatus
  dailyBudgetMinor Int?
  optimizationGoal String?
  billingEvent     String?
  targeting        Json?
  syncedAt         DateTime
}

enum CreativeFormat {
  VIDEO
  REELS
  CAROUSEL
  IMAGE
}

model Creative {
  id              String             @id @default(cuid())
  metaCreativeId  String             @unique
  name            String
  format          CreativeFormat
  thumbnailUrl    String?
  metaPostId      String? // effective_object_story_id ("{page}_{post}")
  videoId         String? // creative.video_id — embeds the FB video player (watch?v=)
  permalinkUrl    String? // resolved post permalink (or instagram_permalink_url)
  previewImageUrl String? // full_picture / creative.image_url (larger than thumbnail)
  caption         String? // post message/caption text
  adStatus        AdStatus? // ACTIVE if any ad using it is active, else PAUSED
  profileKey      String? // mock audience profile key (A/B/C); real path uses InsightSnapshot.audience
  productId       String?
  product         Product?           @relation(fields: [productId], references: [id])
  syncedAt        DateTime
  campaigns       CampaignCreative[]
  insights        InsightSnapshot[]
}

model CampaignCreative {
  campaignId String
  creativeId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creative   Creative @relation(fields: [creativeId], references: [id], onDelete: Cascade)

  @@id([campaignId, creativeId])
}

enum InsightLevel {
  ACCOUNT
  CAMPAIGN
  ADSET
  AD
  CREATIVE
}

model InsightSnapshot {
  id          String       @id @default(cuid())
  level       InsightLevel
  window      String
  campaignId  String?
  creativeId  String?
  adAccountId String?
  campaign    Campaign?    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creative    Creative?    @relation(fields: [creativeId], references: [id], onDelete: Cascade)
  spend       Decimal
  impressions Int
  clicks      Int
  ctr         Float
  cpm         Float
  reach       Int
  frequency   Float
  roas        Float
  purchases   Int
  cpa         Float
  cpp         Float
  cpr         Float
  audience    Json?
  video       Json? // { plays3s, thruplays, p25,p50,p75,p100, avgWatchSec, hookRate, holdRate }
  engagement  Json? // { reactions, comments, shares, saves, postEngagement }
  fetchedAt   DateTime

  @@index([level, window, campaignId])
  @@index([level, window, creativeId])
}

// Account-level audience breakdown (age/gender/region/hour/day) per window, for
// the Breakdown page. `data` holds raw sums (BreakdownAccum) so the API can sum
// across accounts then recompute pct/ROAS. One row per (account, window).
model BreakdownSnapshot {
  id          String    @id @default(cuid())
  window      String
  adAccountId String
  adAccount   AdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  data        Json
  fetchedAt   DateTime

  @@unique([adAccountId, window])
}

// ---------------- Automation · Activity · Notifications ----------------
model Rule {
  id          String        @id @default(cuid())
  name        String
  scope       String
  ifCondition String
  thenAction  String
  type        String
  tone        String
  runs        Int           @default(0)
  lastRunAt   DateTime?
  on          Boolean       @default(true)
  metaRuleId  String?
  logs        ActivityLog[]
}

enum LogType {
  BUDGET_UP
  BUDGET_DOWN
  PAUSE
  RESUME
  AUTO_CLOSE
  SCALE
  KPI_EDIT
}

model ActivityLog {
  id         String      @id @default(cuid())
  occurredAt DateTime    @default(now())
  actor      ChangeActor
  userId     String?
  ruleId     String?
  user       User?       @relation(fields: [userId], references: [id])
  rule       Rule?       @relation(fields: [ruleId], references: [id])
  type       LogType
  campaignId String?
  productId  String?
  title      String
  detail     String
  beforeVal  String?
  afterVal   String?

  @@index([occurredAt])
}

model Notification {
  id        String    @id @default(cuid())
  kind      String
  title     String
  detail    String
  createdAt DateTime  @default(now())
  readAt    DateTime?
}

// Durable sync state — one row per kind. The UNIQUE(kind) row is both a cross-tab /
// cross-instance lock (claimed with an atomic conditional update) and the progress
// record the client polls while a detached background sync runs. `updatedAt` is the
// liveness heartbeat: a "running" row that stops updating is treated as stale.
model SyncRun {
  id         String    @id @default(cuid())
  kind       String    @unique // full | map | range | status
  rangeKey   String? // today | custom (kind=range)
  status     String    @default("idle") // idle | running | done | error
  pct        Int       @default(0)
  stage      String    @default("")
  counts     Json? // SyncResult / RangeSyncResult once done
  error      String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  updatedAt  DateTime  @updatedAt
}
