# AdsHub — environment template (safe to commit; NO secrets here).
# Copy to .env.local (Meta) and .env (DATABASE_URL). See .ai/meta-integration.md + .ai/schema.md.

# Database (Prisma + Next). Local Postgres example:
DATABASE_URL="postgresql://USER@localhost:5432/adshub?schema=public"

# Meta app (Marketing API). App ID is not secret.
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v23.0

# Access token — paste into .env.local only, never here.
# Auto-close (pausing campaigns in Meta) needs the `ads_management` scope; a
# read-only `ads_read` token still syncs but cannot pause.
META_ACCESS_TOKEN=

# Comma-separated act_ ad account ids the token may manage.
META_AD_ACCOUNTS=

# Auto-close write-back (OPT-IN, default off): when "on", each sync PAUSES in Meta
# any breaching campaign whose product has auto-close on. Left off, breaching
# campaigns are flag-only ("ควรปิด") and nothing is written back to Meta.
META_AUTO_CLOSE=off

# Background on/off status poller (default on): mirrors each campaign's ACTIVE/PAUSED
# from Meta into the cache so the dashboard tracks Business Suite without a manual
# sync. Read-only (status only, no insights). Long-running node only — on Vercel use
# a vercel.json cron hitting POST /api/sync/status. Set "off" to disable.
META_STATUS_POLL=on
META_STATUS_POLL_SECONDS=120

# Object storage via S3 — product image / creative attachments.
# Works with Supabase Storage's S3 gateway or any S3 bucket.
# Supabase: Storage → Settings → S3 Connection (endpoint + region + new access key).
# Credentials are secret → paste into .env.local only. Bucket must be Public for image URLs.
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=attachments
