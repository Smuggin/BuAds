# AdsHub — environment template (safe to commit; NO secrets here).
# Copy to .env.local (Meta) and .env (DATABASE_URL). See .ai/meta-integration.md + .ai/schema.md.

# Database (Prisma + Next). Local Postgres example:
DATABASE_URL="postgresql://USER@localhost:5432/adshub?schema=public"

# --- Auth & sessions ---
# Login is required for the whole app, by USERNAME (not email). Accounts are
# admin-managed (no signup). Set the admin username + password by seeding, then
# unset these:
#   SEED_ADMIN_USERNAME='butas' SEED_ADMIN_PASSWORD='choose-a-strong-one' npm run db:seed
# Applied to the admin user; re-run to rotate. Do NOT leave set in Vercel build env.
SEED_ADMIN_USERNAME=
SEED_ADMIN_PASSWORD=

# Optional override for the session cookie name.
SESSION_COOKIE_NAME=adshub_session

# Optional pepper mixed into every password hash — extra defense if the DB leaks.
# Keep it ONLY in env, never in the DB. Generate: openssl rand -base64 32
# Rotating it invalidates all existing passwords.
AUTH_PEPPER=

# Shared secret Vercel cron sends as `Authorization: Bearer`. When set, the
# /api/cron/daily route rejects anything without it. Generate: openssl rand -base64 32
CRON_SECRET=

# Meta app (Marketing API). App ID is not secret.
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v23.0

# Access token — paste into .env.local only, never here.
# Auto-close (pausing campaigns in Meta) needs the `ads_management` scope; a
# read-only `ads_read` token still syncs but cannot pause.
META_ACCESS_TOKEN=

# Comma-separated act_ ad account ids the token may manage.
# For READS/sync, empty = all accounts the token can reach.
# For WRITES, this is the ALLOWLIST and empty = NONE (fail-closed): a write is
# refused unless the target campaign's account is listed here. Scope it to your
# sandbox act_ id(s) while testing.
META_AD_ACCOUNTS=

# MASTER SWITCH for ALL Meta write-backs (pause/resume, budget) — default off.
# Nothing is ever written to Meta unless this is "on" AND the target account is in
# META_AD_ACCOUNTS. Also gates auto-close and the nightly budget-reset cron, and the
# /api/meta/write-test endpoint. Keep off until deliberately going live.
META_WRITES_ENABLED=off

# Auto-close write-back (OPT-IN, default off): when "on", each sync PAUSES in Meta
# any breaching campaign whose product has auto-close on. Left off, breaching
# campaigns are flag-only ("ควรปิด") and nothing is written back to Meta.
# NOTE: even with this "on", writes still require META_WRITES_ENABLED=on + allowlist.
META_AUTO_CLOSE=off

# Background on/off status poller (default on): mirrors each campaign's ACTIVE/PAUSED
# from Meta into the cache so the dashboard tracks Business Suite without a manual
# sync. Read-only (status only, no insights). Long-running node only — on Vercel use
# a vercel.json cron hitting POST /api/sync/status. Set "off" to disable.
META_STATUS_POLL=on
META_STATUS_POLL_SECONDS=120

# Object storage via S3 — product image / creative attachments.
# Works with Supabase Storage's S3 gateway or any S3 bucket.
# Supabase: Storage → Settings → S3 Connection (endpoint + region + new access key).
# Credentials are secret → paste into .env.local only. Bucket must be Public for image URLs.
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=attachments
